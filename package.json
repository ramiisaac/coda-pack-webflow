{
  "name": "coda-webflow",
  "version": "1.0.0",
  "description": "A Coda Pack for Webflow API integration",
  "main": "src/pack.ts",
  "scripts": {
    "build": "coda build src/pack.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "test": "mocha",
    "coda:build": "coda build src/pack.ts",
    "coda:validate": "coda validate src/pack.ts",
    "coda:upload": "coda upload src/pack.ts",
    "coda:release": "coda release src/pack.ts 49 -n \"Portfolio polish and release\""
  },
  "author": "Rami Isaac <raisaac@icloud.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ramiisaac/coda_webflow"
  },
  "homepage": "https://github.com/ramiisaac/coda_webflow#readme",
  "bugs": {
    "url": "https://github.com/ramiisaac/coda_webflow/issues"
  },
  "keywords": [
    "webflow",
    "api",
    "cms",
    "coda",
    "coda-pack",
    "pack"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@codahq/packs-sdk": "^1.13.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.1",
    "@types/chai": "^4.3.12",
    "@types/mocha": "^10.0.6",
    "@types/node": "^25.6.0",
    "@types/sinon": "^21.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "chai": "^4.4.1",
    "eslint": "^9.20.1",
    "eslint-plugin-prettier": "^5.5.5",
    "locate-path": "6",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "sinon": "^21.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@9.12.3",
  "type": "commonjs"
}
