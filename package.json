{
  "name": "coda-webflow-api",
  "version": "1.0.0",
  "description": "A Coda Pack for Webflow API integration",
  "main": "src/pack.ts",
  "scripts": {
    "build": "coda build src/pack.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "test": "mocha",
    "coda:build": "coda build src/pack.ts",
    "coda:validate": "coda validate src/pack.ts",
    "coda:upload": "coda upload src/pack.ts",
    "coda:release": "coda release src/pack.ts"
  },
  "author": "Rami Isaac <raisaac@icloud.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ramiisaac/coda_webflow-api"
  },
  "homepage": "https://github.com/ramiisaac/coda_webflow-api#readme",
  "bugs": {
    "url": "https://github.com/ramiisaac/coda_webflow-api/issues"
  },
  "keywords": [
    "webflow",
    "api",
    "cms",
    "coda",
    "pack"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@codahq/packs-sdk": "^1.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.1",
    "@types/chai": "^4.3.12",
    "@types/mocha": "^10.0.6",
    "@types/node": "^22.13.4",
    "@types/sinon": "^17.0.3",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "chai": "^4.4.1",
    "eslint": "^9.20.1",
    "eslint-plugin-prettier": "^5.2.3",
    "locate-path": "6",
    "mocha": "^11.1.0",
    "prettier": "^3.5.1",
    "sinon": "^17.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.12.3",
  "type": "commonjs"
}
