{
  "name": "webflow-coda-pack",
  "version": "1.0.0",
  "description": "A Coda Pack for Webflow API integration",
  "main": "src/pack.ts",
  "scripts": {
    "postinstall": "npx patch-package",
    "test": "mocha --require ts-node/register test/*.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "build": "npm run validate && tsc",
    "validate": "coda validate src/pack.ts",
    "upload": "coda upload src/pack.ts"
  },
  "author": "Rami Isaac <https://github.com/ramiisaac>",
  "license": "MIT",
  "dependencies": {
    "@codahq/packs-sdk": "^1.8.3",
    "axios": "^1.6.7",
    "encoding": "^0.1.13",
    "openapi-typescript": "^7.4.3",
    "ts-morph": "^24.0.0",
    "webflow-api": "^2.4.2"
  },
  "devDependencies": {
    "@types/chai": "^4.3.12",
    "@types/chai-as-promised": "^7.1.7",
    "@types/content-disposition": "^0.5.8",
    "@types/jest": "^29.5.12",
    "@types/jsrsasign": "^10.5.12",
    "@types/luxon": "^3.4.2",
    "@types/mime-types": "^2.1.3",
    "@types/mocha": "^10.0.6",
    "@types/node": "^18.19.18",
    "@types/sinon": "^10.0.20",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/experimental-utils": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "chai": "4.3.12",
    "chai-as-promised": "7.1.8",
    "eslint": "^8.57.0",
    "eslint-plugin-ban": "^1.6.0",
    "eslint-plugin-filenames": "^1.3.2",
    "eslint-plugin-local": "^1.0.0",
    "eslint-plugin-prefer-let": "^3.0.1",
    "eslint-plugin-prettier": "^5.1.3",
    "mocha": "10.0.6",
    "node": "20.11.25",
    "openapi-typescript-codegen": "^0.29.0",
    "patch-package": "8.0.0",
    "prettier": "^3.2.5",
    "sinon": "17.0.3",
    "ts-node": "10.9.2",
    "typescript": "^5.7.2"
  }
}
